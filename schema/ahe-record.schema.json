{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ahe-record.schema.json",
  "title": "AHE LAB Record Collection",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "id",
      "title",
      "medium",
      "year",
      "publishedAt",
      "score",
      "intensity",
      "status",
      "tags",
      "note",
      "circle",
      "characters"
    ],
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^AHE-[0-9]{4}$"
      },
      "title": {
        "type": "string",
        "minLength": 1
      },
      "medium": {
        "type": "string",
        "minLength": 1
      },
      "year": {
        "type": "integer",
        "minimum": 1900,
        "maximum": 2100
      },
      "publishedAt": {
        "type": "string",
        "format": "date"
      },
      "score": {
        "type": "integer",
        "minimum": 0,
        "maximum": 100
      },
      "intensity": {
        "type": "string",
        "enum": ["Low", "Medium", "High"]
      },
      "status": {
        "type": "string",
        "enum": ["Draft", "Researching", "Cataloged", "Reviewed"]
      },
      "tags": {
        "type": "array",
        "minItems": 1,
        "uniqueItems": true,
        "items": {
          "type": "string",
          "minLength": 1
        }
      },
      "note": {
        "type": "string",
        "minLength": 1
      },
      "circle": {
        "type": "string",
        "minLength": 1
      },
      "characters": {
        "type": "array",
        "minItems": 1,
        "uniqueItems": true,
        "items": {
          "type": "string",
          "minLength": 1
        }
      },
      "performers": {
        "type": "array",
        "minItems": 1,
        "uniqueItems": true,
        "items": {
          "type": "string",
          "minLength": 1
        }
      },
      "maker": {
        "type": "string",
        "minLength": 1
      },
      "label": {
        "type": "string",
        "minLength": 1
      },
      "release": {
        "type": "string",
        "format": "date"
      },
      "runtime": {
        "type": "string",
        "minLength": 1
      },
      "archiveNote": {
        "type": "string",
        "minLength": 1
      },
      "reviewerNote": {
        "type": "string",
        "minLength": 1
      },
      "sourceNote": {
        "type": "string",
        "minLength": 1
      },
      "curatorNote": {
        "type": "string",
        "minLength": 1
      },
      "verification": {
        "type": "string",
        "minLength": 1
      },
      "metadata": {
        "type": "object",
        "additionalProperties": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "number"
            },
            {
              "type": "boolean"
            }
          ]
        },
        "properties": {
          "productId": {
            "type": "string",
            "minLength": 1
          },
          "maker": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "runtime": {
            "type": "string",
            "minLength": 1
          },
          "verification": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "scoreDetails": {
        "type": "object",
        "minProperties": 1,
        "additionalProperties": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        }
      },
      "rating": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "eyeFocus": {
            "type": "integer",
            "minimum": 0,
            "maximum": 10
          },
          "tongueOut": {
            "type": "integer",
            "minimum": 0,
            "maximum": 10
          },
          "drool": {
            "type": "integer",
            "minimum": 0,
            "maximum": 10
          },
          "doublePeace": {
            "type": "integer",
            "minimum": 0,
            "maximum": 10
          },
          "tearsPien": {
            "type": "integer",
            "minimum": 0,
            "maximum": 10
          },
          "pleasure": {
            "type": "integer",
            "minimum": 0,
            "maximum": 10
          },
          "despairFear": {
            "type": "integer",
            "minimum": 0,
            "maximum": 10
          },
          "loyaltySubmission": {
            "type": "integer",
            "minimum": 0,
            "maximum": 10
          },
          "expressionDuration": {
            "type": "integer",
            "minimum": 0,
            "maximum": 10
          },
          "workConcept": {
            "type": "integer",
            "minimum": 0,
            "maximum": 10
          }
        }
      },
      "tagCategories": {
        "type": "object",
        "minProperties": 1,
        "additionalProperties": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "communityReviews": {
        "type": "array",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["nickname", "createdAt", "rating", "comment"],
          "properties": {
            "nickname": {
              "type": "string",
              "minLength": 1
            },
            "role": {
              "type": "string",
              "minLength": 1
            },
            "createdAt": {
              "type": "string",
              "format": "date"
            },
            "rating": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "eyeFocus": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 10
                },
                "tongueOut": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 10
                },
                "drool": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 10
                },
                "doublePeace": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 10
                },
                "tearsPien": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 10
                },
                "pleasure": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 10
                },
                "despairFear": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 10
                },
                "fearDespair": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 10
                },
                "loyaltySubmission": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 10
                },
                "submission": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 10
                },
                "expressionDuration": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 10
                },
                "duration": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 10
                },
                "workConcept": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 10
                },
                "concept": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 10
                }
              }
            },
            "comment": {
              "type": "string",
              "minLength": 1
            },
            "helpfulCount": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      },
      "thumbnail": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "accent", "background"],
        "properties": {
          "label": {
            "type": "string",
            "minLength": 1
          },
          "accent": {
            "type": "string",
            "pattern": "^#[0-9A-Fa-f]{6}$"
          },
          "background": {
            "type": "string",
            "pattern": "^#[0-9A-Fa-f]{6}$"
          }
        }
      }
    }
  }
}
